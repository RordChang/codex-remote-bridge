CODEX_COMMAND=codex
CODEX_WORKDIR=C:\path\to\your\workspace
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh
CODEX_PERMISSION=read-only
CODEX_CONTEXT_MODE=native
CODEX_ALLOWED_MODELS=gpt-5.5,gpt-5.4
CODEX_TIMEOUT_SECONDS=1800
RECENT_DEFAULT_COUNT=5
MAX_HISTORY_CHARS=12000

# QQ official Gateway mode.
# C2C and group @ messages usually use 1<<25.
# Add INTERACTION_CREATE when Markdown/Keyboard buttons are enabled.
QQ_APP_ID=replace-with-qq-app-id
QQ_APP_SECRET=replace-with-qq-app-secret
QQ_API_BASE=https://api.sgroup.qq.com
QQ_AUTH_URL=https://bots.qq.com/app/getAppAccessToken
QQ_GATEWAY_PATH=/gateway
QQ_GATEWAY_INTENTS=33554432
QQ_ALLOWED_EVENTS=C2C_MESSAGE_CREATE,GROUP_AT_MESSAGE_CREATE
QQ_REPLY_MAX_CHARS=1500
QQ_MAX_REPLY_CHUNKS=5
QQ_JOB_QUEUE_SIZE=20
QQ_CODEX_MAX_PARALLEL=5
QQ_TASK_STATUS_INTERVAL_SECONDS=300
QQ_TASK_PARTIAL_INTERVAL_SECONDS=60
QQ_TASK_PARTIAL_MAX_CHARS=1200
QQ_SEND_PARTIAL_OUTPUTS=0
QQ_SHOW_TASK_CONTEXT_ON_FINAL=1
QQ_TRUNCATE_LONG_REPLIES=1
QQ_SEND_PROCESSING_MESSAGE=0
QQ_PROCESSING_TEXT=
QQ_SEND_STARTUP_TO_ALLOWED_USERS=1
QQ_ATTACHMENT_DOWNLOAD=1
QQ_ATTACHMENT_MAX_COUNT=4
QQ_ATTACHMENT_MAX_BYTES=26214400
QQ_SEND_LOCAL_IMAGES=1
QQ_SEND_IMAGE_MAX_COUNT=4
QQ_SEND_IMAGE_MAX_BYTES=10485760
QQ_RESTART_DELAY_SECONDS=2

# Optional labels and allowlists.
# QQ Gateway authorization should use openid, not a plain QQ number.
QQ_OWNER_QQ=
QQ_ALLOWED_USER_OPENIDS=
QQ_ALLOWED_GROUP_OPENIDS=
